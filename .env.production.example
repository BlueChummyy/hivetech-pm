# ── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_USER=hivetech
POSTGRES_PASSWORD=CHANGE_ME_to_a_strong_password
POSTGRES_DB=hivetech

# ── JWT Secrets ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_generate_a_random_secret
JWT_REFRESH_SECRET=CHANGE_ME_generate_a_different_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Public URL ──────────────────────────────────────────────────────
# The URL users will access the app at (used for CORS and WebSocket)
PUBLIC_URL=https://pm.example.com
CORS_ORIGIN=https://pm.example.com

# ── Server ──────────────────────────────────────────────────────────
# Port the frontend Nginx will listen on (mapped to host)
PORT=80

# ── File Uploads ────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
